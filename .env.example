# 复制为 .env 后填写；勿将 .env 提交到 Git。
# 飞书 App ID 一般为 cli_ 开头；勿将火山 ep-/ark- 误填到 FEISHU_*。

FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxxxxxxxxx
# 本批终态报告里「人才库行直达链接」的域名；国内 https://www.feishu.cn；飞书国际版可改为 https://www.larksuite.com
FEISHU_LINK_BASE=https://www.feishu.cn

# 若报错「127.0.0.1:7890 拒绝连接 / ProxyError」：系统里配了代理但 Clash 等未开。
# 设下面为 1，让本项目的 Python 请求不走代理（国内直连飞书/火山）；需要代理时再改回 0 并启动代理软件。
DISABLE_HTTP_PROXY=1

# 大模型：OpenAI 兼容协议，默认火山方舟。只需填三项（说明见 docs/llm.md）
# LLM_MODEL = 方舟控制台「端点/EP」ID，整串 ep- 开头
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.3

SCHEDULER_TICK_SECONDS=5
SCREENER_CONSISTENCY_VAR_THRESHOLD=100
# 三面评分最大-最小 >= 该值则进入辩论
INTERVIEW_SPREAD_THRESHOLD=3
DEBATE_MAX_ROUNDS=3
# 每 tick 从人才池最多「二次投递」几条（反向激活）
REACTIVATION_MAX_PER_TICK=2
# 可选：飞书群机器人 Webhook，Analyst 周报后推送摘要
FEISHU_REPORT_WEBHOOK=
# 经理仲裁性别反事实双评：1=开 0=关（关则仅单次仲裁）
FAIRNESS_COUNTERFACTUAL_ENABLED=1
# 飞书机器人结果监听：pipeline 每变一阶段就推一条；0=关（建议关，减少刷屏）
FEISHU_BOT_NOTIFY_STEPS=0
# 有人到终态时是否逐人再推一条；0=关（默认关，终态攒到本批结束出一份总报告）
FEISHU_BOT_NOTIFY_EACH_TERMINAL=0
# 本批全部终态后写入项目下目录（相对项目根；空=只发飞书）。同次会多生成一个 .html「一眼看板」——浏览器打开、分栏配色，比扫多维表更直观
FEISHU_BOT_REPORT_DIR=reports
# 上项轮询间隔（秒），默认 8
FEISHU_BOT_POLL_SECONDS=8
LOG_LEVEL=INFO
