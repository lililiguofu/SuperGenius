# 复制为 .env 后填写；勿将 .env 提交到 Git。
# 飞书 App ID 一般为 cli_ 开头；勿将火山 ep-/ark- 误填到 FEISHU_*。

FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxxxxxxxxx

# 若报错「127.0.0.1:7890 拒绝连接 / ProxyError」：系统里配了代理但 Clash 等未开。
# 设下面为 1，让本项目的 Python 请求不走代理（国内直连飞书/火山）；需要代理时再改回 0 并启动代理软件。
DISABLE_HTTP_PROXY=1

# 大模型：OpenAI 兼容协议，默认火山方舟。只需填三项（说明见 docs/llm.md）
# LLM_MODEL = 方舟控制台「端点/EP」ID，整串 ep- 开头
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.3

SCHEDULER_TICK_SECONDS=5
SCREENER_CONSISTENCY_VAR_THRESHOLD=100
LOG_LEVEL=INFO
